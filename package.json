{
  "name": "syncfiles",
  "version": "1.0.0",
  "description": "SyncFiles — Logiciel de synchronisation de fichiers",
  "main": "out/main/index.js",
  "author": {
    "name": "Gracie Raseta",
    "email": "gracieraseta@gmail.com"
  },
  "scripts": {
    "dev":        "electron-vite dev",
    "build":      "electron-vite build",
    "start":      "electron-vite preview",
    "engine:dev": "npx ts-node src/main.ts",
    "dist:win":   "npm run build && electron-builder --win"
  },
  "build": {
    "appId":       "mg.edu.esp.syncfiles",
    "productName": "SyncFiles",
    "copyright":   "Copyright © 2026 ESP Antsiranana",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch":   ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "SyncFiles-Portable-${version}.exe"
    }
  },
  "dependencies": {
    "mysql2":     "^3.9.2",
    "chokidar":   "^3.6.0",
    "node-cron":  "^3.0.3",
    "winston":    "^3.11.0",
    "uuid":       "^9.0.1",
    "minimatch":  "^9.0.4",
    "react":      "^18.2.0",
    "react-dom":  "^18.2.0",
    "bcryptjs":   "^2.4.3",
    "nodemailer": "^6.9.9"
  },
  "devDependencies": {
    "@types/node":          "^20.11.5",
    "@types/node-cron":     "^3.0.11",
    "@types/uuid":          "^9.0.7",
    "@types/react":         "^18.2.0",
    "@types/react-dom":     "^18.2.0",
    "@types/bcryptjs":      "^2.4.6",
    "@types/nodemailer":    "^6.4.14",
    "typescript":           "^5.3.3",
    "ts-node":              "^10.9.2",
    "electron":             "^29.0.0",
    "electron-vite":        "^2.0.0",
    "electron-builder":     "^24.13.3",
    "@vitejs/plugin-react": "^4.2.1",
    "vite":                 "^5.0.0"
  }
}
